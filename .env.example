TOPSTEPX_USERNAME=your_topstepx_username
TOPSTEPX_API_KEY=your_topstepx_api_key

# Leave blank to auto-select the first tradable active account.
TOPSTEPX_ACCOUNT_ID=

# Practice/sim should be false. Only set true for a live data/order environment.
TOPSTEPX_LIVE=false

# MNQ is strongly recommended while testing.
TOPSTEPX_SYMBOL=MNQ
TOPSTEPX_CONTRACTS=1

# Safety: dry run prints orders but does not submit them.
BOT_DRY_RUN=true
BOT_POLL_SECONDS=20
BOT_LOOKBACK_MINUTES=2880

# Signal throttles.
BOT_MAX_TRADES_PER_DAY=3
BOT_MIN_BARS_BETWEEN_SIGNALS=20
BOT_FIRST_SIGNAL_PRESSURE=0.45
BOT_NORMAL_PRESSURE=0.30
BOT_SKIP_SHORTS_BEFORE_0800=true
BOT_FIRST_TRADE_LONGS_ONLY=false
BOT_USE_ROUND_LEVELS=false

# Bracket distances.
BOT_LEVEL_TOLERANCE=20
BOT_STOP_POINTS=23
BOT_TAKE_PROFIT_POINTS=40
BOT_TRIM2_POINTS=70
BOT_RUNNER_POINTS=175
